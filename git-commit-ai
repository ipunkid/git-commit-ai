#!/usr/bin/env python3
"""
git-commit-ai — AI-powered commit message generator for lazygit

Supports: OpenAI, DeepSeek, Anthropic, Gemini, Grok, Qwen, MiniMax, GLM, Kimi
"""

import os
import sys
import json
import subprocess
import urllib.request
import urllib.error
import tempfile

CONFIG_DIR = os.path.expanduser("~/.config/git-commit-ai")
CONFIG_FILE = os.path.join(CONFIG_DIR, "config.json")

DEFAULT_ENDPOINTS = {
    "openai": "https://api.openai.com/v1",
    "deepseek": "https://api.deepseek.com/v1",
    "grok": "https://api.x.ai/v1",
    "qwen": "https://dashscope.aliyuncs.com/compatible-mode/v1",
    "minimax": "https://api.minimax.chat/v1",
    "glm": "https://open.bigmodel.cn/api/paas/v4",
    "kimi": "https://api.moonshot.cn/v1",
    "anthropic": "https://api.anthropic.com/v1",
    "gemini": "https://generativelanguage.googleapis.com/v1",
}

DEFAULT_MODELS = {
    "openai": "gpt-4.1-mini",
    "deepseek": "deepseek-v4-flash",
    "grok": "grok-4.3",
    "qwen": "qwen-plus",
    "minimax": "minimax-m2.5",
    "glm": "glm-5",
    "kimi": "kimi-k2.6",
    "anthropic": "claude-sonnet-4-6",
    "gemini": "gemini-2.5-flash",
}

OPENAI_FORMAT = {"openai", "deepseek", "grok", "qwen", "minimax", "glm", "kimi"}

PROVIDER_LABELS = {
    "openai": "OpenAI",
    "deepseek": "DeepSeek",
    "grok": "Grok (xAI)",
    "qwen": "Qwen (Alibaba)",
    "minimax": "MiniMax",
    "glm": "GLM (Zhipu)",
    "kimi": "Kimi (Moonshot)",
    "anthropic": "Claude (Anthropic)",
    "gemini": "Gemini (Google)",
}

SYSTEM_PROMPT = (
    "Generate a concise one-line git commit message describing the changes. "
    "Output only the commit message, no explanation."
)


def get_diff():
    diff = subprocess.run(
        ["git", "diff", "--cached"], capture_output=True, text=True
    ).stdout.strip()
    if not diff:
        diff = subprocess.run(
            ["git", "diff"], capture_output=True, text=True
        ).stdout.strip()
    if not diff:
        print("No changes detected")
        sys.exit(1)
    return diff


def get_branch():
    return subprocess.run(
        ["git", "rev-parse", "--abbrev-ref", "HEAD"],
        capture_output=True, text=True,
    ).stdout.strip()


def load_config():
    if not os.path.exists(CONFIG_FILE):
        os.makedirs(CONFIG_DIR, exist_ok=True)
        cfg = build_default_config()
        with open(CONFIG_FILE, "w") as f:
            json.dump(cfg, f, indent=2)
        print(f"Created default config at {CONFIG_FILE}", file=sys.stderr)
        return cfg
    with open(CONFIG_FILE) as f:
        return json.load(f)


def save_config(cfg):
    os.makedirs(CONFIG_DIR, exist_ok=True)
    with open(CONFIG_FILE, "w") as f:
        json.dump(cfg, f, indent=2)


def build_default_config():
    providers = {}
    for name in DEFAULT_ENDPOINTS:
        env_var = f"{name.upper()}_API_KEY"
        providers[name] = {
            "api_key": f"${{{env_var}}}",
            "model": DEFAULT_MODELS[name],
            "endpoint": DEFAULT_ENDPOINTS[name],
        }
    return {"provider": "deepseek", "providers": providers}


def resolve_api_key(name, cfg):
    env_var = f"{name.upper()}_API_KEY"
    val = os.environ.get(env_var, "")
    if val:
        return val.strip()
    raw = cfg.get("api_key", "")
    if raw.startswith("${") and raw.endswith("}"):
        var = raw[2:-1]
        return os.environ.get(var, "").strip()
    return raw.strip()


def http_post(url, headers, payload):
    data = json.dumps(payload).encode()
    req = urllib.request.Request(url, data=data, headers=headers)
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            return json.loads(resp.read())
    except urllib.error.HTTPError as e:
        print(f"HTTP {e.code}: {e.read().decode()}")
        sys.exit(1)
    except urllib.error.URLError as e:
        print(f"Request failed: {e.reason}")
        sys.exit(1)


def call_openai(endpoint, model, key, diff, branch):
    data = http_post(
        f"{endpoint}/chat/completions",
        {"Content-Type": "application/json", "Authorization": f"Bearer {key}"},
        {
            "model": model,
            "messages": [
                {"role": "system", "content": SYSTEM_PROMPT},
                {"role": "user", "content": f"Branch: {branch}\n\nDiff:\n{diff}"},
            ],
            "max_tokens": 80,
            "temperature": 0.1,
        },
    )
    return data["choices"][0]["message"]["content"].strip()


def call_anthropic(endpoint, model, key, diff, branch):
    data = http_post(
        f"{endpoint}/messages",
        {
            "Content-Type": "application/json",
            "x-api-key": key,
            "anthropic-version": "2023-06-01",
        },
        {
            "model": model,
            "max_tokens": 80,
            "temperature": 0.1,
            "system": SYSTEM_PROMPT,
            "messages": [{"role": "user", "content": f"Branch: {branch}\n\nDiff:\n{diff}"}],
        },
    )
    return data["content"][0]["text"].strip()


def call_gemini(endpoint, model, key, diff, branch):
    data = http_post(
        f"{endpoint}/models/{model}:generateContent?key={key}",
        {"Content-Type": "application/json"},
        {
            "contents": [
                {
                    "role": "user",
                    "parts": [{"text": f"{SYSTEM_PROMPT}\n\nBranch: {branch}\n\nDiff:\n{diff}"}],
                }
            ],
            "generationConfig": {"maxOutputTokens": 80, "temperature": 0.1},
        },
    )
    return data["candidates"][0]["content"]["parts"][0]["text"].strip()


def generate_message():
    cfg = load_config()
    name = cfg.get("provider", "deepseek")
    pcfg = cfg.get("providers", {}).get(name)
    if not pcfg:
        print(f"Provider '{name}' not found in config")
        sys.exit(1)

    key = resolve_api_key(name, pcfg)
    if not key:
        print(
            f"API key for '{name}' not found. "
            f"Set ${name.upper()}_API_KEY or configure in {CONFIG_FILE}"
        )
        sys.exit(1)

    model = pcfg.get("model") or DEFAULT_MODELS.get(name, "")
    endpoint = pcfg.get("endpoint") or DEFAULT_ENDPOINTS.get(name, "")
    diff = get_diff()
    branch = get_branch()

    if name == "anthropic":
        return call_anthropic(endpoint, model, key, diff, branch)
    if name == "gemini":
        return call_gemini(endpoint, model, key, diff, branch)
    return call_openai(endpoint, model, key, diff, branch)


def cmd_gen():
    print(generate_message())


def cmd_commit():
    msg = generate_message()
    proc = subprocess.run(
        ["git", "commit", "-F", "-"], input=msg, capture_output=True, text=True
    )
    if proc.stdout:
        print(proc.stdout, end="")
    if proc.stderr:
        print(proc.stderr, end="")
    if proc.returncode != 0:
        sys.exit(proc.returncode)


def cmd_edit():
    msg = generate_message()
    editor = (
        os.environ.get("GIT_EDITOR")
        or os.environ.get("VISUAL")
        or os.environ.get("EDITOR")
        or "vim"
    )
    fd, path = tempfile.mkstemp(prefix="git-commit-ai-", suffix=".txt", text=True)
    try:
        with os.fdopen(fd, "w") as f:
            f.write(msg + "\n")
        subprocess.run([editor, path])
        with open(path) as f:
            edited = f.read().strip()
        if not edited:
            print("Empty message, commit aborted")
            sys.exit(1)
        proc = subprocess.run(
            ["git", "commit", "-F", "-"], input=edited, capture_output=True, text=True
        )
        if proc.stdout:
            print(proc.stdout, end="")
        if proc.stderr:
            print(proc.stderr, end="")
        if proc.returncode != 0:
            sys.exit(proc.returncode)
    finally:
        os.unlink(path)


def cmd_set_provider(name):
    cfg = load_config()
    if name not in cfg.get("providers", {}):
        available = ", ".join(sorted(cfg["providers"]))
        print(f"Unknown provider '{name}'. Available: {available}")
        sys.exit(1)
    cfg["provider"] = name
    save_config(cfg)
    print(f"Switched to {PROVIDER_LABELS.get(name, name)}")


def cmd_list():
    cfg = load_config()
    current = cfg.get("provider", "")
    for name in sorted(cfg.get("providers", {})):
        marker = ">" if name == current else " "
        label = PROVIDER_LABELS.get(name, name)
        env_var = f"{name.upper()}_API_KEY"
        key_ok = "Y" if os.environ.get(env_var) else "."
        model = cfg["providers"][name].get("model", "")
        print(f" {marker} [{key_ok}] {label:<30s} {model}")


def cmd_show_config():
    cfg = load_config()
    print(json.dumps(cfg, indent=2))


def cmd_help():
    print(
        """Usage: git-commit-ai <command>

Commands:
  (none)         Generate commit message to stdout
  gen            Generate commit message to stdout
  commit         Generate message and run git commit
  edit           Generate, edit in editor, then commit
  set-provider   Switch to a different AI provider
  list           List configured providers and their status
  config         Show current configuration
  help           Show this help message

Config: ~/.config/git-commit-ai/config.json

API keys are read from environment variables (e.g. $DEEPSEEK_API_KEY)
with fallback to the api_key field in config.json."""
    )


def main():
    cmd = sys.argv[1] if len(sys.argv) > 1 else "gen"

    if cmd in ("gen", "generate"):
        cmd_gen()
    elif cmd == "commit":
        cmd_commit()
    elif cmd == "edit":
        cmd_edit()
    elif cmd in ("set-provider", "switch"):
        if len(sys.argv) < 3:
            print("Usage: git-commit-ai set-provider <provider_name>")
            sys.exit(1)
        cmd_set_provider(sys.argv[2])
    elif cmd in ("list", "ls"):
        cmd_list()
    elif cmd == "config":
        cmd_show_config()
    elif cmd in ("help", "--help", "-h"):
        cmd_help()
    else:
        print(f"Unknown command: {cmd}")
        cmd_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
